generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          Role      @default(PENDAFTAR)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  pendaftar Pendaftar?
  sessions  Session[]
  accounts  Account[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PANITIA
  PENDAFTAR
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── REFERENSI ────────────────────────────────────────────────

model ProgramStudi {
  id        String      @id @default(cuid())
  kode      String      @unique
  nama      String
  jenjang   Jenjang
  aktif     Boolean     @default(true)
  kuota     Int         @default(100)
  pendaftar Pendaftar[]
}

enum Jenjang {
  S1
  D3
  D4
}

model PeriodePMB {
  id           String      @id @default(cuid())
  nama         String
  tahunAjaran  String
  tanggalBuka  DateTime
  tanggalTutup DateTime
  aktif        Boolean     @default(false)
  pendaftar    Pendaftar[]
}

// ─── PENDAFTAR ────────────────────────────────────────────────

model Pendaftar {
  id            String     @id @default(cuid())
  noPendaftaran String     @unique
  userId        String     @unique
  periodeId     String
  prodiId       String
  jalurMasuk    JalurMasuk @default(REGULER)
  status        StatusPMB  @default(MENUNGGU_VERIFIKASI)

  // Data Pribadi
  nama         String
  nik          String       @unique
  tempatLahir  String
  tanggalLahir DateTime
  jenisKelamin JenisKelamin
  agama        String
  alamat       String
  kota         String
  provinsi     String
  kodePos      String?
  noHp         String
  email        String

  // Data Pendidikan
  asalSekolah    String
  jurusanSekolah String
  tahunLulus     Int
  nilaiRataRata  Decimal? @db.Decimal(4, 2)

  // Data Orang Tua
  namaAyah      String?
  namaIbu       String?
  pekerjaanOrtu String?
  noHpOrtu      String?

  // Catatan dari panitia
  catatanVerifikasi String?

  // Relasi
  user          User            @relation(fields: [userId], references: [id])
  periode       PeriodePMB      @relation(fields: [periodeId], references: [id])
  prodi         ProgramStudi    @relation(fields: [prodiId], references: [id])
  dokumen       Dokumen[]
  riwayatStatus RiwayatStatus[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum JalurMasuk {
  REGULER
  BEASISWA
  TRANSFER
  KERJASAMA
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum StatusPMB {
  MENUNGGU_VERIFIKASI
  DOKUMEN_TIDAK_LENGKAP
  TERVERIFIKASI
  TERDAFTAR_TES
  LULUS_TES
  TIDAK_LULUS_TES
  DITERIMA
  DITOLAK
  DAFTAR_ULANG
  MENGUNDURKAN_DIRI
}

model RiwayatStatus {
  id          String     @id @default(cuid())
  pendaftarId String
  statusLama  StatusPMB?
  statusBaru  StatusPMB
  catatan     String?
  diubahOleh  String
  createdAt   DateTime   @default(now())
  pendaftar   Pendaftar  @relation(fields: [pendaftarId], references: [id])
}

model Dokumen {
  id          String        @id @default(cuid())
  pendaftarId String
  jenis       JenisDokumen
  namaFile    String
  urlFile     String
  ukuranFile  Int
  status      StatusDokumen @default(MENUNGGU)
  catatan     String?
  uploadedAt  DateTime      @default(now())
  verifiedAt  DateTime?
  pendaftar   Pendaftar     @relation(fields: [pendaftarId], references: [id])
}

enum JenisDokumen {
  FOTO
  KTP
  KARTU_KELUARGA
  IJAZAH_ATAU_SKL
  TRANSKRIP_NILAI
  SERTIFIKAT_PRESTASI
}

enum StatusDokumen {
  MENUNGGU
  VALID
  DITOLAK
}
